# Copy to .env and fill in. NEVER commit .env.

# Neon (or any public Postgres with pgvector). Keep ?sslmode=require.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Azure AD service principal with access to the Azure OpenAI resource.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Bare Azure AI resource endpoint (not the /api/projects/... URL).
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21

# Comma-separated bearer tokens accepted from MCP clients. Generate long random values,
# e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEYS=

# Extra Host header values to accept (DNS-rebinding allow-list), comma-separated.
# The Render deployment host is added automatically; only needed for custom domains.
# Set to "*" to disable the check entirely.
MCP_ALLOWED_HOSTS=

# --- Only needed to run scripts/agent_demo.py (the Foundry agentic-RAG demo) ---
# Not needed by the server itself.
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
MCP_PUBLIC_URL=https://your-service.onrender.com/mcp

APP_LOG_LEVEL=INFO
